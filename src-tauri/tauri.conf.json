{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "st-of-chengming",
  "version": "1.0.3",
  "identifier": "cl.com",
  "build": {
    "beforeDevCommand": "trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ST Launcher",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "targets": ["msi"],
    "publisher": "chengming",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
